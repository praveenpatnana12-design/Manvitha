{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api"
    },
    {
      "source": "/invoices/:path*",
      "destination": "/api"
    },
    {
      "source": "/statements/:path*",
      "destination": "/api"
    },
    {
      "source": "/((?!api|invoices|statements).*)$",
      "destination": "/index.html"
    }
  ]
}
